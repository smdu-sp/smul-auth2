generator client {
  provider = "prisma-client"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "mysql"
}

enum Permissao {
  ADMIN
  USER
}

model Usuario {
  id            String    @id @default(uuid())
  login         String    @unique
  email         String    @unique
  nome          String?

  permissao     Permissao @default(USER)

  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@map("usuarios")
}

model Servidor {
  id            String  @id @default(uuid())
  ip            String  @unique
  nome          String?
  status        Boolean  @default(true)

  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  @@map("servidores")
}
